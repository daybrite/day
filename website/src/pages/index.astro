---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeSample from '../components/CodeSample.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import InstallCommand from '../components/InstallCommand.astro';
import Logo from '../components/Logo.astro';
import { url, site } from '../lib/site';
import { platforms } from '../../gallery.config.mjs';

// Group the eleven CI targets by OS for the "runs on" grid.
const byOs = platforms.reduce((acc, p) => {
  (acc[p.os] ??= []).push(p);
  return acc;
}, {} as Record<string, typeof platforms>);

const heroCode = `use day::prelude::*;

fn counter() -> AnyPiece {
    let count = Signal::new(0i64);
    column((
        label(move || format!("{} clicks", count.get())),
        row((
            button("–").action(move || count.update(|c| *c -= 1)),
            button("+").action(move || count.update(|c| *c += 1)),
        )).spacing(8.0),
    ))
    .spacing(12.0)
    .padding(16.0)
    .any()
}`;

const navCode = `let section = Signal::new(String::new());
selector(section)
    .style(SelectorStyle::Sidebar)   // native split view / tabs / pushing list
    .item("home",     "Home",     home_page)
    .item("settings", "Settings", settings_page)`;

const features = [
  {
    icon: '◉',
    title: 'Apps your users recognize',
    body: 'Every control is the platform’s own — a real Mac button on macOS, real Material on Android. Text, scrolling, shortcuts, and dark mode behave the way each platform’s users already expect, and keep improving with OS updates you never have to ship.',
  },
  {
    icon: '↯',
    title: 'No browser, no bundled engine',
    body: 'Day apps are small native binaries that talk directly to the operating system. There is no embedded browser to patch and no rendering engine to carry, so apps start fast, stay lean, and leave a smaller security surface to maintain.',
  },
  {
    icon: '⬢',
    title: 'One codebase, one team',
    body: 'Six operating systems from a single Rust program. A feature lands once and ships everywhere at the same time — instead of three implementations drifting apart across three teams and three schedules.',
  },
  {
    icon: '✦',
    title: 'Accessibility & localization, built in',
    body: 'Screen-reader support rides each platform’s own accessibility tree, and every user-facing string flows through Mozilla Fluent localization. The groundwork for accessibility requirements and new markets is in the framework, not on your backlog.',
  },
  {
    icon: '◱',
    title: 'Proven on every platform, every change',
    body: 'Each commit builds a full demo app on all eleven targets, drives it end to end, and captures screenshots — the gallery on this site is those exact artifacts. Platform regressions surface in CI, not in your users’ reviews.',
  },
  {
    icon: '⌘',
    title: 'Tooling teams actually use',
    body: 'One command line creates, runs, tests, and packages signed installers for every platform — dmg, App Store, Android, flatpak, Windows. The same automation scripts drive the app everywhere, built for CI and AI-assisted development alike.',
  },
];

// Honest one-paragraph contrasts for teams evaluating a cross-platform stack. Factual and
// non-disparaging — the docs' "Why Day (and why not)" page carries the full, frank comparison.
const compare = [
  {
    name: 'Web-view shells',
    examples: 'Electron, Tauri',
    body: 'Fast to staff from a web team, but the interface runs in a browser engine — bundled with the app (Electron) or the system’s (Tauri) — with the memory profile, patch cadence, and not-quite-native feel that implies.',
  },
  {
    name: 'Custom renderers',
    examples: 'Flutter, Iced',
    body: 'Pixel-identical screens everywhere, drawn by the framework rather than the platform. Text, scrolling, and accessibility are re-implementations, and the app looks the same everywhere instead of at home anywhere.',
  },
  {
    name: 'Per-platform native',
    examples: 'Swift + Kotlin + C++ teams',
    body: 'The most flexibility and fidelity, but paid for once per platform. Every feature is built, reviewed, and maintained N times, and the versions drift apart when schedules diverge.',
  },
];
---
<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1 class="hero-title">
          <span class="grad-text">Day</span>: create native apps for every platform{' '}
          <span class="sun-text">under the sun</span> from a single Rust codebase
        </h1>
        <p class="lead hero-lead">{site.description}</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={url('docs/overview')}>Read the docs</a>
          <a class="btn btn-ghost" href={url('gallery')}>See it running →</a>
        </div>
      </div>
      <div class="hero-media">
        <HeroCarousel />
      </div>
    </div>
    <div class="container hero-install">
      <InstallCommand />
    </div>
  </section>

  <!-- RUNS ON -->
  <section class="section runs">
    <div class="container">
      <p class="eyebrow">Runs natively on</p>
      <div class="os-grid">
        {Object.entries(byOs).map(([os, list]) => (
          <div class="os-card">
            <h3>{os}</h3>
            <ul>
              {list.map((p) => <li><span class="tick">◆</span>{p.toolkit}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- THE CODE -->
  <section class="section codeshow">
    <div class="container codeshow-grid">
      <div class="codeshow-copy">
        <p class="eyebrow">One codebase, every platform</p>
        <h2 class="sec-title">One Rust function. A native app <span class="grad-text">everywhere</span>.</h2>
        <p class="lead">
          This is a complete, working counter — the whole thing. The same function becomes a real
          AppKit control on macOS, UIKit on iOS, Material on Android, and native GTK, Qt, WinUI, and
          ArkUI widgets everywhere else. Those are the screenshots in the carousel above: real
          platform components, from this exact kind of code.
        </p>
        <ul class="how-list">
          <li><b>Just Rust:</b> plain functions and builder calls — no markup language, no macros, no per-platform branches.</li>
          <li><b>Reactive by binding:</b> change a signal and only the control showing it updates — no re-render, no virtual tree.</li>
          <li><b>Native on the other side:</b> the widgets it produces are the platform's own, not lookalikes drawn by an engine.</li>
        </ul>
        <div class="hero-cta">
          <a class="btn btn-ghost" href={url('docs/api-tour')}>See the full API tour →</a>
        </div>
      </div>
      <div class="codeshow-code">
        <CodeSample code={heroCode} title="counter.rs" />
        <p class="codeshow-note">One function — a native counter on all eleven targets.</p>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section features">
    <div class="container">
      <p class="eyebrow">Why Day</p>
      <h2 class="sec-title">Native quality <span class="grad-text">and</span> a single codebase.</h2>
      <p class="lead">
        Cross-platform tools usually make you choose between apps that feel native and a codebase
        you only write once. Day is built to deliver both — and to be frank about the trade-offs.
      </p>
      <div class="feat-grid">
        {features.map((f) => (
          <div class="card feat">
            <div class="feat-icon" aria-hidden="true">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARE -->
  <section class="section compare">
    <div class="container">
      <p class="eyebrow">Evaluating your options</p>
      <h2 class="sec-title">Every approach trades something. Know what.</h2>
      <div class="cmp-grid">
        {compare.map((c) => (
          <div class="card cmp">
            <h3>{c.name}</h3>
            <p class="cmp-ex">{c.examples}</p>
            <p>{c.body}</p>
          </div>
        ))}
      </div>
      <p class="lead cmp-close">
        Day keeps the platform's own components <em>and</em> the single codebase. It has real limits
        too — no hot reload, a young ecosystem, deliberate constraints on pixel-level branding — and
        the documentation states them plainly, including the cases where a different choice is right
        for you.
      </p>
      <a class="btn btn-ghost" href={url('docs/benefits')}>Read the frank comparison →</a>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section how">
    <div class="container how-grid">
      <div>
        <p class="eyebrow">How it works</p>
        <h2 class="sec-title">When data changes, the right control updates. That's it.</h2>
        <p class="lead">
          Day builds your interface from real platform components once, then keeps each one
          connected to your application's state. When a value changes, the exact label or control
          showing it updates — no re-rendering, no shadow copy of the interface to reconcile, no
          engine in between. Day apps perform like hand-written platform code because, at runtime,
          that's essentially what they are.
        </p>
        <ul class="how-list">
          <li><b>Plain Rust:</b> functions and builder calls any engineer can read — no macros, no separate UI language.</li>
          <li><b>Native navigation:</b> sidebars, tabs, and back-gestures are the platform's own containers.</li>
          <li><b>Testable end to end:</b> one automation script drives the app identically on every platform.</li>
        </ul>
        <div class="hero-cta">
          <a class="btn btn-ghost" href={url('docs/api-tour')}>Full API tour →</a>
          <a class="btn btn-ghost" href={url('docs/rendering')}>Under the hood →</a>
        </div>
      </div>
      <div class="how-code">
        <CodeSample code={navCode} title="navigation.rs" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta">
    <div class="container cta-inner">
      <Logo size={40} />
      <h2>Build it once. Ship it everywhere your users are.</h2>
      <div class="hero-cta">
        <a class="btn btn-primary" href={url('docs/getting-started')}>Get started</a>
        <a class="btn btn-ghost" href={url('gallery')}>Browse the gallery</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero { position: relative; overflow: hidden; padding-block: 72px 40px; }
  .hero-glow {
    position: absolute;
    top: -280px; left: 50%;
    width: 1100px; height: 700px;
    transform: translateX(-50%);
    background: radial-gradient(closest-side, rgba(255, 150, 90, 0.22), rgba(106, 164, 255, 0.14) 55%, transparent 72%);
    filter: blur(6px);
    pointer-events: none;
  }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 52px;
    align-items: center;
  }
  /* Grid items must be allowed to shrink below their content's intrinsic width, so a wide
     code block scrolls inside its own box instead of stretching the page. */
  .hero-grid > *, .how-grid > * { min-width: 0; }
  .hero-title { font-size: clamp(2.3rem, 5.2vw, 3.7rem); margin: 0 0 20px; font-weight: 800; line-height: 1.08; }
  /* "under the sun" in a warm amber gradient — a nod to the Ember Dawn mark. */
  .sun-text {
    background: linear-gradient(100deg, var(--sun) 0%, var(--sun-2) 100%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
    white-space: nowrap;
  }
  .hero-lead { margin: 0 0 28px; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 12px; }
  .hero-install { margin-top: 34px; }

  /* THE CODE (example moved down from the hero) */
  .codeshow-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 48px; align-items: center; }
  .codeshow-grid > * { min-width: 0; }
  .codeshow-note { color: var(--faint); font-size: 0.84rem; margin: 14px 2px 0; text-align: center; }

  /* RUNS ON */
  .os-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(180px, 100%), 1fr)); gap: 16px; margin-top: 8px; }
  .os-card { border: 1px solid var(--border-soft); border-radius: var(--radius); padding: 18px 20px; background: var(--surface); }
  .os-card h3 { margin: 0 0 12px; font-size: 1.05rem; }
  .os-card ul { list-style: none; margin: 0; padding: 0; }
  .os-card li { color: var(--muted); font-size: 0.92rem; padding: 4px 0; display: flex; align-items: center; gap: 8px; }
  .tick { color: var(--sun); font-size: 0.7rem; }

  /* section headers */
  .sec-title { font-size: clamp(1.7rem, 3.6vw, 2.4rem); margin: 0 0 14px; }

  /* FEATURES */
  .feat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(268px, 100%), 1fr)); gap: 18px; margin-top: 34px; }
  .feat { transition: border-color 0.15s ease, transform 0.12s ease; }
  .feat:hover { border-color: var(--border); transform: translateY(-3px); }
  .feat-icon {
    width: 42px; height: 42px; display: grid; place-items: center;
    border-radius: 11px; margin-bottom: 14px; font-size: 1.15rem;
    background: rgba(106, 164, 255, 0.12); color: var(--brand);
  }
  .feat h3 { margin: 0 0 8px; font-size: 1.12rem; }
  .feat p { margin: 0; color: var(--muted); font-size: 0.95rem; }

  /* COMPARE */
  .cmp-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(268px, 100%), 1fr)); gap: 18px; margin-top: 34px; }
  .cmp h3 { margin: 0 0 2px; font-size: 1.08rem; }
  .cmp-ex { margin: 0 0 10px; color: var(--faint); font-size: 0.84rem; }
  .cmp p:last-child { margin: 0; color: var(--muted); font-size: 0.95rem; }
  .cmp-close { margin: 30px 0 18px; max-width: 68ch; }

  /* HOW */
  .how-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 48px; align-items: center; }
  .how-list { list-style: none; padding: 0; margin: 20px 0 26px; }
  .how-list li { color: var(--muted); padding: 8px 0 8px 26px; position: relative; }
  .how-list li::before { content: '◆'; color: var(--sun); position: absolute; left: 0; font-size: 0.72rem; top: 12px; }
  .how-list b { color: var(--text); }

  /* CTA */
  .cta-inner {
    text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 18px;
    padding: 56px 28px;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(closest-side at 50% 0%, rgba(255, 150, 90, 0.12), transparent 70%),
      var(--surface);
  }
  .cta-inner h2 { font-size: clamp(1.5rem, 3.4vw, 2.1rem); margin: 0; max-width: 20ch; }

  @media (max-width: 880px) {
    .hero-grid, .how-grid, .codeshow-grid { grid-template-columns: minmax(0, 1fr); }
    .hero { padding-top: 40px; }
    .how-code { order: 2; }
    /* On the hero, keep the copy (info column) first — above the carousel — on narrow screens
       (source order; no reorder). */
  }
</style>
