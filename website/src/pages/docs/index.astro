---
import { getCollection } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { url } from '../../lib/site';

const docs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
---
<DocsLayout title="Documentation" description="day documentation: overview, benefits, API tour, and CLI.">
  <h1>Documentation</h1>
  <p class="lead">Start with the overview, then tour the API and the tooling.</p>
  <div class="doc-cards">
    {docs.map((d) => (
      <a class="doc-card" href={url(`docs/${d.id}`)}>
        <h3>{d.data.title}</h3>
        <p>{d.data.description}</p>
      </a>
    ))}
  </div>
</DocsLayout>

<style>
  .doc-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; margin-top: 26px; }
  .doc-card {
    display: block;
    padding: 20px;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    background: var(--surface);
    transition: border-color 0.15s ease, transform 0.12s ease;
  }
  .doc-card:hover { border-color: var(--brand); transform: translateY(-2px); }
  .doc-card h3 { margin: 0 0 6px; color: var(--text); }
  .doc-card p { margin: 0; color: var(--muted); font-size: 0.94rem; }
</style>
