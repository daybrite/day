---
import { url } from '../lib/site';
// Pagefind indexes the built site (`pagefind --site dist` in the build script) into /pagefind/.
// Its UI is generated at build time, so search works in production and `preview`, not `dev`.
const pagefindJs = url('pagefind/pagefind-ui.js');
const pagefindCss = url('pagefind/pagefind-ui.css');
---
<button type="button" class="search-trigger" data-search-open aria-label="Search" aria-keyshortcuts="Meta+K Control+K">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" />
  </svg>
  <span class="st-text">Search</span>
  <kbd>⌘K</kbd>
</button>

<dialog class="search-modal" data-search-dialog aria-label="Search the site" data-pagefind-ignore>
  <div class="search-panel">
    <div id="pagefind-search" data-search-mount></div>
  </div>
</dialog>

<script is:inline define:vars={{ pagefindJs, pagefindCss }}>
  (() => {
    const dialog = document.querySelector('[data-search-dialog]');
    const mount = document.querySelector('[data-search-mount]');
    if (!dialog || !mount) return;
    let loaded = false;

    function load() {
      if (loaded) return Promise.resolve();
      loaded = true;
      return new Promise((resolve) => {
        const css = document.createElement('link');
        css.rel = 'stylesheet';
        css.href = pagefindCss;
        document.head.appendChild(css);
        const js = document.createElement('script');
        js.src = pagefindJs;
        js.onload = () => {
          // eslint-disable-next-line no-undef
          new PagefindUI({ element: mount, showSubResults: true, showImages: false, resetStyles: false });
          resolve();
        };
        js.onerror = () => {
          mount.innerHTML =
            '<p class="search-unavailable">The search index is built at deploy time. Run a production build (<code>scripts/website.sh preview</code>) to try it locally.</p>';
          resolve();
        };
        document.body.appendChild(js);
      });
    }

    async function open() {
      await load();
      if (!dialog.open) dialog.showModal();
      setTimeout(() => dialog.querySelector('input')?.focus(), 40);
    }
    const close = () => dialog.open && dialog.close();

    document.querySelectorAll('[data-search-open]').forEach((b) => b.addEventListener('click', open));
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        dialog.open ? close() : open();
      }
    });
    // Click on the backdrop (outside the panel) closes; Esc is handled natively by <dialog>.
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close();
    });
  })();
</script>

<style>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 34px;
    padding: 0 10px 0 11px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--hover);
    color: var(--muted);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .search-trigger:hover { color: var(--text); border-color: var(--brand); }
  .search-trigger svg { width: 15px; height: 15px; }
  .search-trigger kbd {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--faint);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1px 5px;
  }

  .search-modal {
    /* Pagefind UI theming — inherited by the widget mounted inside. */
    --pagefind-ui-primary: var(--brand);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--surface);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--surface-2);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 10px;
    --pagefind-ui-font: var(--font);

    width: min(640px, calc(100vw - 32px));
    max-height: min(70vh, 640px);
    margin: 12vh auto auto;
    padding: 18px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    box-shadow: var(--shadow);
    overflow: auto;
  }
  .search-modal::backdrop {
    background: rgba(4, 7, 14, 0.55);
    backdrop-filter: blur(4px);
  }
  .search-unavailable { color: var(--muted); font-size: 0.92rem; margin: 6px 2px; }

  @media (max-width: 620px) {
    .search-trigger .st-text, .search-trigger kbd { display: none; }
    .search-trigger { padding: 0 9px; }
  }
</style>
