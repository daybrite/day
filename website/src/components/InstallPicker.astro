---
// InstallPicker — a tabbed one-liner installer chooser (shell / Windows / Homebrew / cargo),
// with copy-to-clipboard and OS auto-detection. The commands fetch the installer scripts that
// the release-cli CI job renders and attaches to every tagged release (scripts/release/).
//
// Usable from .astro pages and .mdx docs alike; all styling is self-contained and the script
// is idempotent per element, so several pickers can coexist on one page.
interface Props {
  /** Compact spacing for embedding inside docs prose. */
  compact?: boolean;
}
const { compact = false } = Astro.props;

const tabs = [
  {
    id: 'shell',
    label: 'macOS / Linux',
    command:
      "curl --proto '=https' --tlsv1.2 -LsSf https://github.com/daybrite/day/releases/latest/download/day-installer.sh | sh",
  },
  {
    id: 'windows',
    label: 'Windows',
    command:
      'powershell -ExecutionPolicy Bypass -c "irm https://github.com/daybrite/day/releases/latest/download/day-installer.ps1 | iex"',
  },
  {
    id: 'brew',
    label: 'Homebrew',
    command:
      'curl -LO https://github.com/daybrite/day/releases/latest/download/day.rb && brew install --formula ./day.rb',
  },
  {
    id: 'cargo',
    label: 'Cargo',
    command: 'cargo install --locked --git https://github.com/daybrite/day day-cli',
  },
];
---
<div class:list={['install-picker', { compact }]} data-install-picker>
  <div class="ip-tabs" role="tablist" aria-label="Installation method">
    {tabs.map((t, i) => (
      <button
        class:list={['ip-tab', { active: i === 0 }]}
        role="tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        data-tab={t.id}
        type="button"
      >{t.label}</button>
    ))}
  </div>
  {tabs.map((t, i) => (
    <div class:list={['ip-panel', { hidden: i !== 0 }]} data-panel={t.id} role="tabpanel">
      <code class="ip-cmd" data-command>{t.command}</code>
      <button class="ip-copy" type="button" data-copy aria-label="Copy command" title="Copy">
        <span class="ip-copy-icon" aria-hidden="true">⧉</span>
        <span class="ip-copy-done" aria-hidden="true">✓</span>
      </button>
    </div>
  ))}
  <p class="ip-note">
    Every release asset is checksummed and carries GitHub build-provenance attestation
    (<code>gh attestation verify</code>).
  </p>
</div>

<script>
  function initPicker(root: Element) {
    if ((root as HTMLElement).dataset.ipInit) return;
    (root as HTMLElement).dataset.ipInit = '1';

    const tabs = root.querySelectorAll<HTMLButtonElement>('[data-tab]');
    const panels = root.querySelectorAll<HTMLElement>('[data-panel]');
    const select = (id: string) => {
      tabs.forEach((t) => {
        const on = t.dataset.tab === id;
        t.classList.toggle('active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      panels.forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== id));
    };
    tabs.forEach((t) => t.addEventListener('click', () => select(t.dataset.tab!)));

    // Preselect the visitor's platform (shell is already the default for macOS/Linux).
    const ua = navigator.userAgent;
    if (/Windows/i.test(ua)) select('windows');

    root.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const cmd = btn.parentElement?.querySelector('[data-command]')?.textContent ?? '';
        try {
          await navigator.clipboard.writeText(cmd);
        } catch {
          const range = document.createRange();
          range.selectNodeContents(btn.parentElement!.querySelector('[data-command]')!);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
          document.execCommand('copy');
          sel?.removeAllRanges();
        }
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 2000);
      });
    });
  }
  const initAll = () => document.querySelectorAll('[data-install-picker]').forEach(initPicker);
  initAll();
  document.addEventListener('astro:page-load', initAll);
</script>

<style>
  .install-picker {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 14px;
    max-width: 720px;
  }
  .install-picker.compact { padding: 10px; }
  .ip-tabs { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
  .ip-tab {
    appearance: none;
    border: 1px solid var(--border-soft);
    background: transparent;
    color: var(--muted);
    font: inherit;
    font-size: 0.86rem;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 999px;
    cursor: pointer;
  }
  .ip-tab:hover { color: var(--text); border-color: var(--border); }
  .ip-tab.active {
    color: var(--text);
    background: rgba(106, 164, 255, 0.12);
    border-color: var(--brand);
  }
  .ip-panel {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border-soft);
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.18);
    padding: 10px 12px;
  }
  :global([data-theme='light']) .ip-panel { background: rgba(0, 0, 0, 0.05); }
  .ip-panel.hidden { display: none; }
  .ip-cmd {
    flex: 1;
    min-width: 0;
    font-size: 0.82rem;
    line-height: 1.5;
    overflow-x: auto;
    white-space: nowrap;
    background: none;
    padding: 0;
  }
  .ip-copy {
    appearance: none;
    border: 1px solid var(--border-soft);
    background: transparent;
    color: var(--muted);
    border-radius: 8px;
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    cursor: pointer;
    flex: none;
  }
  .ip-copy:hover { color: var(--text); border-color: var(--border); }
  .ip-copy .ip-copy-done { display: none; color: var(--sun); }
  .ip-copy.copied .ip-copy-icon { display: none; }
  .ip-copy.copied .ip-copy-done { display: block; }
  .ip-note { margin: 10px 2px 0; color: var(--faint); font-size: 0.78rem; }
  .ip-note code { font-size: 0.76rem; }
</style>
