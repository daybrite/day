---
import Logo from './Logo.astro';
import { url, site } from '../lib/site';
---
<footer class="footer">
  <div class="container foot-inner">
    <div class="foot-brand">
      <a class="brand" href={url()} aria-label="day home"><Logo size={22} /><span>day</span></a>
      <p class="foot-tag">{site.tagline}</p>
    </div>
    <nav class="foot-cols" aria-label="Footer">
      <div>
        <h4>Docs</h4>
        <a href={url('docs/overview')}>Overview</a>
        <a href={url('docs/benefits')}>Why day</a>
        <a href={url('docs/api-tour')}>API tour</a>
        <a href={url('docs/cli')}>CLI &amp; projects</a>
      </div>
      <div>
        <h4>Explore</h4>
        <a href={url('gallery')}>Screenshot gallery</a>
        <a href={site.repo} rel="noopener">Source ↗</a>
      </div>
    </nav>
  </div>
  <div class="container foot-legal">
    <span>Built with Astro. Native everywhere.</span>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--border-soft); background: var(--bg-2); padding-block: 52px 28px; margin-top: 40px; }
  .foot-inner { display: flex; flex-wrap: wrap; gap: 40px; justify-content: space-between; }
  .brand { display: inline-flex; align-items: center; gap: 9px; color: var(--text); font-weight: 750; font-size: 1.05rem; }
  .foot-tag { color: var(--faint); max-width: 34ch; margin: 12px 0 0; font-size: 0.92rem; }
  .foot-cols { display: flex; gap: 56px; }
  .foot-cols h4 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--faint); margin: 0 0 12px; }
  .foot-cols a { display: block; color: var(--muted); font-size: 0.94rem; margin-bottom: 8px; }
  .foot-cols a:hover { color: var(--text); }
  .foot-legal { margin-top: 34px; color: var(--faint); font-size: 0.84rem; }
  @media (max-width: 560px) { .foot-cols { gap: 36px; } }
</style>
