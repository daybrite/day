---
// The day mark: a rising sun (dawn = "daybrite") in the brand gradient. Inline SVG so it stays
// crisp at any size and needs no network request. `id` keeps the gradient unique per instance.
interface Props { size?: number; class?: string }
const { size = 28, class: cls = '' } = Astro.props;
const gid = 'daysun-' + Math.random().toString(36).slice(2, 8);
---
<svg
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  class={cls}
  role="img"
  aria-label="day logo"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient id={gid} x1="6" y1="6" x2="42" y2="44" gradientUnits="userSpaceOnUse">
      <stop stop-color="#ffce6e" />
      <stop offset="0.42" stop-color="#ff8f5e" />
      <stop offset="1" stop-color="#6aa4ff" />
    </linearGradient>
  </defs>
  <!-- rays -->
  <g stroke={`url(#${gid})`} stroke-width="3" stroke-linecap="round">
    <path d="M24 3.5v5" />
    <path d="M24 39.5v5" />
    <path d="M3.5 24h5" />
    <path d="M39.5 24h5" />
    <path d="M9.6 9.6l3.5 3.5" />
    <path d="M34.9 34.9l3.5 3.5" />
    <path d="M38.4 9.6l-3.5 3.5" />
    <path d="M13.1 34.9l-3.5 3.5" />
  </g>
  <!-- disc -->
  <circle cx="24" cy="24" r="10.5" fill={`url(#${gid})`} />
</svg>
