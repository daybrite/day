---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '../lib/site';

interface Props { title: string; description?: string; slug?: string; active?: string }
const { title, description, slug, active = 'docs' } = Astro.props;

// Highlight the pinned "API reference" sidebar link when we're on that page.
const isApi = Astro.url.pathname.replace(/\/$/, '').endsWith('/docs/api');

const docs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
const idx = docs.findIndex((d) => d.id === slug);
const prev = idx > 0 ? docs[idx - 1] : null;
const next = idx >= 0 && idx < docs.length - 1 ? docs[idx + 1] : null;

// Group the (already order-sorted) pages into sidebar sections. A section's position is set
// by its first page, so ordering lives entirely in frontmatter.
const sections: { name: string; pages: typeof docs }[] = [];
for (const d of docs) {
  const last = sections[sections.length - 1];
  if (last && last.name === d.data.section) last.pages.push(d);
  else {
    const existing = sections.find((s) => s.name === d.data.section);
    if (existing) existing.pages.push(d);
    else sections.push({ name: d.data.section, pages: [d] });
  }
}
---
<BaseLayout title={title} description={description} active={active}>
  <div class="docs container">
    <aside class="sidebar" data-pagefind-ignore>
      <nav aria-label="Documentation">
        {sections.map((s) => (
          <>
            <p class="side-h">{s.name}</p>
            {s.pages.map((d) => (
              <a href={url(`docs/${d.id}`)} class:list={['side-link', { on: d.id === slug }]}>
                {d.data.title}
              </a>
            ))}
          </>
        ))}
        <p class="side-h">Reference</p>
        <a href={url('docs/api')} class:list={['side-link', { on: isApi }]}>API reference</a>
      </nav>
    </aside>

    <article class="doc-body">
      <slot />
      {(prev || next) && (
        <nav class="prevnext" aria-label="Pagination" data-pagefind-ignore>
          {prev ? (
            <a href={url(`docs/${prev.id}`)} class="pn"><span>← Previous</span><b>{prev.data.title}</b></a>
          ) : <span />}
          {next ? (
            <a href={url(`docs/${next.id}`)} class="pn next"><span>Next →</span><b>{next.data.title}</b></a>
          ) : <span />}
        </nav>
      )}
    </article>
  </div>
</BaseLayout>

<style>
  .docs {
    display: grid;
    grid-template-columns: 232px minmax(0, 1fr);
    gap: 48px;
    padding-block: 44px 72px;
    align-items: start;
  }
  .sidebar {
    position: sticky;
    top: 82px;
    align-self: start;
  }
  .side-h {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--faint);
    margin: 0 0 8px;
    font-weight: 700;
  }
  .side-h:not(:first-child) { margin-top: 20px; }
  .side-link {
    display: block;
    padding: 8px 12px;
    border-radius: 9px;
    color: var(--muted);
    font-weight: 600;
    font-size: 0.95rem;
    border-left: 2px solid transparent;
  }
  .side-link:hover { background: var(--hover); color: var(--text); }
  .side-link.on {
    color: var(--text);
    background: rgba(106, 164, 255, 0.1);
    border-left-color: var(--brand);
  }
  .doc-body { max-width: 760px; min-width: 0; overflow-wrap: break-word; }

  .prevnext {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--border-soft);
  }
  .pn {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    min-width: 0;
  }
  .pn.next { text-align: right; }
  .pn span { color: var(--faint); font-size: 0.8rem; }
  .pn b { color: var(--text); }

  @media (max-width: 860px) {
    .docs { grid-template-columns: 1fr; gap: 20px; }
    .sidebar {
      position: static;
      border: 1px solid var(--border-soft);
      border-radius: var(--radius);
      padding: 14px;
    }
    .sidebar nav { display: flex; flex-wrap: wrap; gap: 6px; }
    .side-h { width: 100%; }
    .side-link { border-left: 0; }
  }
</style>

<!-- prose styling for rendered markdown -->
<style is:global>
  .doc-body h1, .doc-body h2, .doc-body h3 { scroll-margin-top: 84px; }
  .doc-body > h1:first-child, .doc-body > :first-child { margin-top: 0; }
  .doc-body h2 {
    font-size: 1.5rem;
    margin: 44px 0 14px;
    padding-top: 20px;
    border-top: 1px solid var(--border-soft);
  }
  .doc-body h3 { font-size: 1.16rem; margin: 30px 0 10px; }
  .doc-body p, .doc-body li { color: var(--muted); }
  .doc-body strong { color: var(--text); }
  .doc-body a { text-decoration: underline; text-underline-offset: 2px; text-decoration-color: rgba(106,164,255,0.4); }
  .doc-body ul, .doc-body ol { padding-left: 22px; }
  .doc-body li { margin: 6px 0; }
  .doc-body pre {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 18px;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.6;
    box-shadow: var(--shadow);
  }
  /* A wide table scrolls within the column instead of widening the page. `display: block`
     makes the table its own horizontal scroll container on narrow screens. */
  .doc-body table {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: 18px 0;
    font-size: 0.93rem;
  }
  .doc-body th, .doc-body td {
    text-align: left;
    padding: 9px 12px;
    border-bottom: 1px solid var(--border-soft);
  }
  .doc-body th { color: var(--text); font-weight: 650; }
  .doc-body td { color: var(--muted); }
  .doc-body td code { white-space: nowrap; }
  .doc-body blockquote {
    margin: 18px 0;
    padding: 4px 16px;
    border-left: 3px solid var(--brand);
    color: var(--muted);
  }
</style>
