{
  "name": "day-vscode",
  "displayName": "Day",
  "description": "Build and run Day apps (cross-platform native UI in Rust) across one or more targets from VS Code.",
  "version": "0.1.0",
  "publisher": "daybrite",
  "repository": {
    "type": "git",
    "url": "https://github.com/skiptools/day",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "day",
    "rust",
    "cross-platform",
    "native",
    "appkit",
    "gtk",
    "qt"
  ],
  "icon": "media/day-icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/day.yaml"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "day",
          "title": "Day",
          "icon": "media/day-icon.svg"
        }
      ]
    },
    "views": {
      "day": [
        {
          "id": "dayTargets",
          "name": "Build & Run",
          "icon": "media/day-icon.svg",
          "contextualTitle": "Day"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dayTargets",
        "contents": "No Day project found in this workspace.\n\nA Day project is a folder containing a [day.yaml](https://daybrite.dev) manifest.\n\n[Refresh](command:day.refresh)"
      }
    ],
    "commands": [
      {
        "command": "day.run",
        "title": "Run Selected Targets",
        "category": "Day",
        "icon": "$(run-all)"
      },
      {
        "command": "day.runTarget",
        "title": "Run",
        "category": "Day",
        "icon": "$(play)"
      },
      {
        "command": "day.build",
        "title": "Build Selected Targets",
        "category": "Day",
        "icon": "$(tools)"
      },
      {
        "command": "day.stop",
        "title": "Stop",
        "category": "Day",
        "icon": "$(debug-stop)"
      },
      {
        "command": "day.stopAll",
        "title": "Stop All",
        "category": "Day",
        "icon": "$(stop-circle)"
      },
      {
        "command": "day.restart",
        "title": "Restart",
        "category": "Day",
        "icon": "$(debug-restart)"
      },
      {
        "command": "day.selectMode",
        "title": "Select Build Mode",
        "category": "Day"
      },
      {
        "command": "day.selectLocale",
        "title": "Select Locale",
        "category": "Day"
      },
      {
        "command": "day.selectScript",
        "title": "Select Dayscript",
        "category": "Day"
      },
      {
        "command": "day.selectProject",
        "title": "Select Project",
        "category": "Day"
      },
      {
        "command": "day.doctor",
        "title": "Doctor (check toolchains)",
        "category": "Day",
        "icon": "$(stethoscope)"
      },
      {
        "command": "day.refresh",
        "title": "Refresh",
        "category": "Day",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "day.run",
          "when": "view == dayTargets",
          "group": "navigation@1"
        },
        {
          "command": "day.stopAll",
          "when": "view == dayTargets",
          "group": "navigation@2"
        },
        {
          "command": "day.refresh",
          "when": "view == dayTargets",
          "group": "navigation@3"
        },
        {
          "command": "day.build",
          "when": "view == dayTargets",
          "group": "1_run@1"
        },
        {
          "command": "day.doctor",
          "when": "view == dayTargets",
          "group": "2_tools@1"
        },
        {
          "command": "day.selectProject",
          "when": "view == dayTargets",
          "group": "2_tools@2"
        }
      ],
      "view/item/context": [
        {
          "command": "day.runTarget",
          "when": "view == dayTargets && viewItem == dayTarget",
          "group": "inline@1"
        },
        {
          "command": "day.stop",
          "when": "view == dayTargets && viewItem == dayTargetRunning",
          "group": "inline@1"
        },
        {
          "command": "day.restart",
          "when": "view == dayTargets && viewItem == dayTargetRunning",
          "group": "inline@2"
        }
      ],
      "commandPalette": [
        {
          "command": "day.runTarget",
          "when": "false"
        },
        {
          "command": "day.stop",
          "when": "false"
        },
        {
          "command": "day.restart",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Day",
      "properties": {
        "day.cliPath": {
          "type": "string",
          "default": "day",
          "markdownDescription": "Path to the `day` CLI binary. If it is not found on `PATH` and the workspace is the Day repository (a Cargo workspace with a `day-cli` member), the extension falls back to `cargo run -q -p day-cli --`."
        },
        "day.defaultProfile": {
          "type": "string",
          "enum": [
            "debug",
            "release"
          ],
          "default": "debug",
          "description": "Default build mode for new workspaces."
        },
        "day.defaultLocale": {
          "type": "string",
          "default": "",
          "description": "Default BCP-47 locale passed to `--locale` (empty = the app/system default)."
        },
        "day.extraEnv": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "description": "Extra environment variables passed to every launch as `--env KEY=VALUE`."
        },
        "day.ohosNdkHome": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the OpenHarmony NDK `native` directory (e.g. `~/ohos-sdk/native`), exported as `OHOS_NDK_HOME` when building/launching the `ohos-arkui` target. Leave empty to auto-detect: the existing `OHOS_NDK_HOME`, then `~/ohos/ndk-extract/native`, then `~/ohos-sdk/native`. The SDK's sibling `toolchains/` directory (which carries `hdc`) is added to the task `PATH` as well."
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "day",
        "required": [
          "command",
          "target"
        ],
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "build",
              "launch"
            ],
            "description": "The day CLI subcommand to run."
          },
          "target": {
            "type": "string",
            "description": "The <os>-<toolkit> target (e.g. macos-appkit, ios-uikit)."
          },
          "profile": {
            "type": "string",
            "enum": [
              "debug",
              "release"
            ],
            "description": "Build mode."
          },
          "locale": {
            "type": "string",
            "description": "BCP-47 locale for --locale."
          },
          "script": {
            "type": "string",
            "description": "Dayscript file to run with --script."
          },
          "project": {
            "type": "string",
            "description": "Project directory (containing day.yaml)."
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
