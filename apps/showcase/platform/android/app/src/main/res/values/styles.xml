<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App theme: Material 3 Expressive (new motion/shape/typography system, material 1.13+),
         follows the system light/dark setting (DayNight), no framework ActionBar (Day renders its
         own nav/toolbar chrome). Requires com.google.android.material. -->
    <style name="AppTheme" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <!-- Rebrand the primary slot group (and the surface tint derived from it) onto the
             Material baseline blue palette; every other role keeps its Material 3 default. -->
        <item name="colorPrimary">@color/showcase_primary</item>
        <item name="colorOnPrimary">@color/showcase_on_primary</item>
        <item name="colorPrimaryContainer">@color/showcase_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/showcase_on_primary_container</item>
        <item name="colorSurfaceTint">@color/showcase_primary</item>
    </style>
</resources>
