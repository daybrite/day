{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "Day on HarmonyOS ArkUI (native Rust cdylib)",
    "mainElement": "EntryAbility",
    // "default" is the OpenHarmony device type the Oniro emulator reports ("phone" is a HarmonyOS-only
    // syscap set, absent from the public OpenHarmony SDK's device-define).
    "deviceTypes": ["default", "tablet"],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    // Required even for the LOOPBACK dayscript engine socket (§14.5): OpenHarmony denies
    // bind/listen without it, and the engine thread dies silently — the scripted-walkthrough
    // channel never comes up. The Android manifest carries the same permission for the same
    // reason.
    "requestPermissions": [
      { "name": "ohos.permission.INTERNET" }
    ],
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "Day ArkUI demo",
        "icon": "$media:startIcon",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": ["entity.system.home"],
            "actions": ["action.system.home"]
          }
        ]
      }
    ]
  }
}
