{
  "app_id": "dev.daybrite.lite.weather",
  "name": "Weather",
  "description": "Current conditions anywhere, via open-meteo",
  "icons": [
    {
      "src": "icon.svg",
      "sizes": "any"
    }
  ],
  "version": {
    "code": 1,
    "name": "1.0.0"
  },
  "platform_version": {
    "min_code": 1
  },
  "pages": [
    "home"
  ],
  "req_permissions": [
    {
      "name": "day.permission.NETWORK",
      "reason": "Fetches forecasts from open-meteo.com"
    }
  ],
  "day": {
    "entry": "app.ts",
    "files": [
      "app.ts",
      "icon.svg",
      "i18n/en.ftl",
      "i18n/fr.ftl",
      "i18n/ar.ftl",
      "i18n/zh-CN.ftl"
    ],
    "net_origins": [
      "https://geocoding-api.open-meteo.com",
      "https://api.open-meteo.com"
    ]
  }
}