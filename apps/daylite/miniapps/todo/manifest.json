{
  "app_id": "dev.daybrite.lite.todo",
  "name": "Todos",
  "description": "A todo list with sqlite persistence and search",
  "icons": [
    {
      "src": "icon.svg",
      "sizes": "any"
    }
  ],
  "version": {
    "code": 1,
    "name": "1.0.0"
  },
  "platform_version": {
    "min_code": 1
  },
  "pages": [
    "home"
  ],
  "req_permissions": [
    {
      "name": "day.permission.STORAGE",
      "reason": "Keeps your todos on this device"
    }
  ],
  "day": {
    "entry": "app.ts",
    "files": [
      "app.ts",
      "icon.svg",
      "i18n/en.ftl",
      "i18n/fr.ftl",
      "i18n/ar.ftl",
      "i18n/zh-CN.ftl"
    ]
  }
}