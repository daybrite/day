{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "Day on HarmonyOS ArkUI (native Rust cdylib)",
    "mainElement": "EntryAbility",
    "deviceTypes": ["phone", "tablet"],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "Day ArkUI demo",
        "icon": "$media:startIcon",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": ["entity.system.home"],
            "actions": ["action.system.home"]
          }
        ]
      }
    ],
    // Loopback sockets (the dayscript engine binds 127.0.0.1) still require the INTERNET
    // permission on HarmonyOS — without it the bind fails silently.
    "requestPermissions": [
      { "name": "ohos.permission.INTERNET" }
    ]
  }
}
