{
  "apiType": "stageMode",
  "buildOption": {
    // No `externalNativeOptions` — Day ships the native module as a PREBUILT cdylib (libentry.so),
    // cross-compiled from Rust by `harmony/build.sh` and dropped into `entry/libs/<abi>/`. hvigor
    // packages `libs/` into the .hap as-is.
    "arkOptions": {}
  },
  "targets": [
    {
      "name": "default",
      "runtimeOS": "HarmonyOS"
    }
  ]
}
