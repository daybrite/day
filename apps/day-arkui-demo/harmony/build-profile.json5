{
  "app": {
    // Fill `signingConfigs` in DevEco Studio (File ▸ Project Structure ▸ Signing Configs ▸ auto-sign),
    // or with the command-line `--sign-hap` flow. HarmonyOS requires a signed .hap to install.
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "5.0.0(12)",
        "runtimeOS": "HarmonyOS"
      }
    ],
    "buildModeSet": [
      { "name": "debug" },
      { "name": "release" }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        { "name": "default", "applyToProducts": ["default"] }
      ]
    }
  ]
}
